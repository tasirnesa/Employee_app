const onboardingService = require('../src/services/onboardingService');
const prisma = require('../src/config/prisma');

async function testOnboarding() {
  console.log('Starting Onboarding Expansion Test...');

  try {
    // 1. Setup mock data
    const mockData = {
      userData: {
        fullName: 'Test Onboarding User',
        userName: `testuser_${Date.now()}`,
        password: 'password123',
        role: 'Employee'
      },
      employeeData: {
        email: `test_${Date.now()}@example.com`,
        firstName: 'Test',
        lastName: 'User',
        phone: '1234567890',
        department: 'Engineering',
        position: 'Software Engineer',
        hireDate: new Date()
      },
      goals: [
        { objective: 'Complete Core Training', priority: 'High' }
      ]
    };

    // Ensure dept/pos exist
    await prisma.department.upsert({
      where: { name: 'Engineering' },
      update: {},
      create: { name: 'Engineering' }
    });
    await prisma.position.create({
      data: { name: 'Software Engineer', level: 3 }
    }).catch(() => {}); // Ignore if exists

    console.log('1. Testing completeWizard...');
    const result = await onboardingService.completeWizard(mockData, 1);
    const onboardingId = result.onboarding.id;
    const employeeId = result.employee.id;
    console.log('✓ completeWizard successful. Onboarding ID:', onboardingId);

    console.log('2. Testing getOnboardingByEmployeeId...');
    const onboarding = await onboardingService.getOnboardingByEmployeeId(employeeId);
    console.log('✓ getOnboarding successful. Tasks count:', onboarding.tasks.length);
    if (onboarding.tasks.length === 0) throw new Error('Default tasks not created');

    console.log('3. Testing createTask...');
    const newTask = await onboardingService.createTask(onboardingId, {
      title: 'Setup GitHub Access',
      description: 'Request access to the repo'
    });
    console.log('✓ createTask successful. Task ID:', newTask.id);

    console.log('4. Testing updateTask (Complete)...');
    const updatedTask = await onboardingService.updateTask(newTask.id, { status: 'Completed' });
    console.log('✓ updateTask successful. Completed At:', updatedTask.completedAt);
    if (!updatedTask.completedAt) throw new Error('completedAt not set');

    console.log('5. Testing createDocument...');
    const newDoc = await onboardingService.createDocument(onboardingId, {
      title: 'Tax Forms',
      description: 'W-4 and State forms'
    });
    console.log('✓ createDocument successful. Doc ID:', newDoc.id);

    console.log('6. Testing assignTraining...');
    const newTraining = await onboardingService.assignTraining(onboardingId, {
      trainingName: 'Security Awareness',
      description: 'Annual security training'
    });
    console.log('✓ assignTraining successful. Training ID:', newTraining.id);

    console.log('7. Testing updateTrainingStatus (InProgress)...');
    const updatedTraining = await onboardingService.assignTraining(onboardingId, { // Wait, I meant updateTrainingStatus
        trainingName: 'Security Awareness 2'
    });
    // Correcting test to call updateTrainingStatus
    const updatedTrainingDone = await onboardingService.updateTrainingStatus(newTraining.id, { status: 'Completed' });
    console.log('✓ updateTrainingStatus successful. Status:', updatedTrainingDone.status);

    console.log('\nALL TESTS PASSED SUCCESSFULLY! 🚀');

  } catch (error) {
    console.error('X TEST FAILED:', error);
  } finally {
    await prisma.$disconnect();
  }
}

testOnboarding();
